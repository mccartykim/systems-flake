From 7b1bbdd654376d5a20f46a15010a67980bef87e0 Mon Sep 17 00:00:00 2001
From: Nicholas Chin <nic.c3.14@gmail.com>
Date: Sun, 6 Apr 2025 10:08:12 -0600
Subject: ec/dell/mec5035/acpi/ec.asl: Add mailbox interface code

Add an ACPI implementation of the mailbox interface driver in mec5035.c.
The vendor firmware only uses this during system initialization as well
as SMI handlers. To minimize the reliance of SMM, add a driver for this
interface to ACPI code so that functionality in the vendor SMI handlers
can be reimplemented in ACPI instead.

Change-Id: I29049fff0ba618d5283086c19939b534f496db9f
Signed-off-by: Nicholas Chin <nic.c3.14@gmail.com>
---
 src/ec/dell/mec5035/acpi/ec.asl         |  1 +
 src/ec/dell/mec5035/acpi/ec_mailbox.asl | 40 +++++++++++++++++++++++++
 2 files changed, 41 insertions(+)
 create mode 100644 src/ec/dell/mec5035/acpi/ec_mailbox.asl

diff --git a/src/ec/dell/mec5035/acpi/ec.asl b/src/ec/dell/mec5035/acpi/ec.asl
index 9391c154..ff8c806a 100644
--- a/src/ec/dell/mec5035/acpi/ec.asl
+++ b/src/ec/dell/mec5035/acpi/ec.asl
@@ -62,6 +62,7 @@ Device (EC)
 		}
 	}
 
+	#include "ec_mailbox.asl"
 	#include "battery.asl"
 	#include "lid.asl"
 }
diff --git a/src/ec/dell/mec5035/acpi/ec_mailbox.asl b/src/ec/dell/mec5035/acpi/ec_mailbox.asl
new file mode 100644
index 00000000..bdb038f9
--- /dev/null
+++ b/src/ec/dell/mec5035/acpi/ec_mailbox.asl
@@ -0,0 +1,40 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+
+/* Mailbox Interface Mutex */
+Mutex (MLCK, 0)
+
+/* EC Mailbox Interface */
+OperationRegion(EMBX, SystemIO, 0x910, 2)
+Field(EMBX, ByteAcc, NoLock, Preserve)
+{
+	EMXI, 8,
+	EMXD, 8,
+}
+
+/* EC Mailbox Read */
+Method (EMXR, 1)
+{
+	EMXI = Arg0 + 0x10
+	Return (EMXD)
+}
+
+/* EC Mailbox Write */
+Method (EMXW, 2)
+{
+	EMXI = Arg0 + 0x10
+	EMXD = Arg1
+}
+
+/* EC Mailbox Command */
+Method (EMXC, 1)
+{
+	EMXI = 0
+	EMXD = Arg0
+
+	/* Wait for EC */
+	Local0 = 1
+	while (Local0) {
+		EMXI = 0
+		Local0 = EMXD
+	}
+}
