From 3a60a5972b18b536effc6de73b8d945764fb177f Mon Sep 17 00:00:00 2001
From: Nicholas Chin <nic.c3.14@gmail.com>
Date: Sun, 6 Apr 2025 10:11:40 -0600
Subject: ec/dell/mec5035/acpi: Add Fan Device

Implement an ACPI Fan Device to report the fan speed. Vendor
firmware handles the fan in SMM and reports the fan speed through the
dell-smm-hwmon driver. Move this functionality into ACPI code to
minimize usage of SMM. Note that this does break fan speed reporting in
programs such as lm-sensors as Linux does not (yet) have a hwmon driver
for ACPI Fan devices. The fan speed can be read from the /sys/bus/acpi/*
device created for the fan.

Change-Id: Idabc6722e532be4ff03fa557e80074872cef2449
Signed-off-by: Nicholas Chin <nic.c3.14@gmail.com>
---
 src/ec/dell/mec5035/acpi/ec.asl      |  1 +
 src/ec/dell/mec5035/acpi/thermal.asl | 51 ++++++++++++++++++++++++++++
 2 files changed, 52 insertions(+)
 create mode 100644 src/ec/dell/mec5035/acpi/thermal.asl

diff --git a/src/ec/dell/mec5035/acpi/ec.asl b/src/ec/dell/mec5035/acpi/ec.asl
index ff8c806a..f84a32f5 100644
--- a/src/ec/dell/mec5035/acpi/ec.asl
+++ b/src/ec/dell/mec5035/acpi/ec.asl
@@ -65,4 +65,5 @@ Device (EC)
 	#include "ec_mailbox.asl"
 	#include "battery.asl"
 	#include "lid.asl"
+	#include "thermal.asl"
 }
diff --git a/src/ec/dell/mec5035/acpi/thermal.asl b/src/ec/dell/mec5035/acpi/thermal.asl
new file mode 100644
index 00000000..1b77693e
--- /dev/null
+++ b/src/ec/dell/mec5035/acpi/thermal.asl
@@ -0,0 +1,51 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+
+Device (FAN)
+{
+	Name (_HID, EISAID ("PNP0C0B"))
+
+	Name (_FIF, Package ()
+	{
+		0,	// Revision
+		1,
+		2,
+		0
+	})
+
+	Name (_FPS, Package ()
+	{
+		0, /* Revision */
+		Package ()
+		{
+			50,
+			0xFFFFFFFF,
+			3000,
+			0xFFFFFFFF,
+			0xFFFFFFFF
+		}
+	})
+
+	Method (_FSL, 1, NotSerialized)
+	{
+	}
+
+	Name (FSTP, Package(){
+		0, /* Revision */
+		50, /* Control */
+		0x00, /* Speed */
+	})
+
+	Method (_FST, 0, NotSerialized)
+	{
+		EMXW(2, 0x02)
+		EMXW(3, 0)
+		EMXW(4, 0)
+		EMXW(5, 0)
+		EMXW(6, 0)
+		EMXC(0x2e)
+		Local0 = EMXR(2)
+		Local0 = (EMXR(3) << 8) | Local0
+		FSTP[2] = Local0
+		Return (FSTP)
+	}
+}
