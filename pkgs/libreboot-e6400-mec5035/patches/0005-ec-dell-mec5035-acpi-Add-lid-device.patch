From aceed641b58266d2bd9b207b091954eda65eecdd Mon Sep 17 00:00:00 2001
From: Nicholas Chin <nic.c3.14@gmail.com>
Date: Sun, 6 Apr 2025 10:09:06 -0600
Subject: ec/dell/mec5035/acpi: Add lid device

Implement a Control Method Lid Device so that lid open/closed events are
sent to the OS.

Change-Id: Iaa9c038e15de7357d5b586518d9296aebd00794b
Signed-off-by: Nicholas Chin <nic.c3.14@gmail.com>
---
 src/ec/dell/mec5035/acpi/ec.asl  | 10 ++++++++++
 src/ec/dell/mec5035/acpi/lid.asl | 13 +++++++++++++
 2 files changed, 23 insertions(+)
 create mode 100644 src/ec/dell/mec5035/acpi/lid.asl

diff --git a/src/ec/dell/mec5035/acpi/ec.asl b/src/ec/dell/mec5035/acpi/ec.asl
index 7a1544d4..9391c154 100644
--- a/src/ec/dell/mec5035/acpi/ec.asl
+++ b/src/ec/dell/mec5035/acpi/ec.asl
@@ -30,11 +30,16 @@ Device (EC)
 		Offset (0x00),
 				ACPR, 1, /* AC Present */
 				BPRT, 1, /* Battery Present */
+				    , 2,
+				LIDS, 1, /* Lid State */
 		Offset (0x05),
 				/* SCI Enable */
 				SCIE, 8,
 	}
 
+	/* Last Lid State */
+	Name (LIDL, 1)
+
 	/* Last Battery Present State */
 	Name (BPRS, 0)
 
@@ -51,7 +56,12 @@ Device (EC)
 			BSTL = BAST
 			Notify(BAT0, 0x80)
 		}
+		if (LIDS != LIDL) {
+			LIDL = LIDS
+			Notify(LID, 0x80)
+		}
 	}
 
 	#include "battery.asl"
+	#include "lid.asl"
 }
diff --git a/src/ec/dell/mec5035/acpi/lid.asl b/src/ec/dell/mec5035/acpi/lid.asl
new file mode 100644
index 00000000..15a9be97
--- /dev/null
+++ b/src/ec/dell/mec5035/acpi/lid.asl
@@ -0,0 +1,13 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+
+Device(LID)
+{
+	Name(_HID, "PNP0C0D")
+
+	Name(_PRW, Package () {24, 3})
+
+	Method(_LID, 0, NotSerialized)
+	{
+		return (LIDS)
+	}
+}
-- 
2.54.0

